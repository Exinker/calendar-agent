import asyncio
import logging
from loguru import logger

from src.models.config import settings


async def main():
    """Main entry point for the calendar bot."""
    logger.info("Starting Calendar Bot...")
    logger.info(f"Admin ID: {settings.admin_user_id}")
    logger.info(f"Database URL: {settings.database_url.split('@')[1] if '@' in settings.database_url else 'configured'}")
    
    # TODO: Initialize bot with whitelist support
    # For now, just test that configuration loads correctly
    logger.info("Configuration loaded successfully!")
    logger.info("Bot is ready to start. Implement telegram handlers next.")
    
    # Keep the process running for testing
    while True:
        await asyncio.sleep(1)


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        logger.info("Bot stopped by user")