TELEGRAM_BOT_TOKEN=
ADMIN_USER_ID=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-3.5-turbo

YANDEX_ENABLED=true
YANDEX_USERNAME=
YANDEX_APP_PASSWORD=

ICLOUD_ENABLED=true
ICLOUD_USERNAME=
ICLOUD_APP_PASSWORD=

DEFAULT_CALENDAR=yandex
TIMEZONE=Europe/Moscow
LOG_LEVEL=INFO

# Database
# DATABASE_URL собирается автоматически по шаблону:
# postgresql+psycopg://{POSTGRES_USER}:{DB_PASSWORD}@{POSTGRES_HOST}:{POSTGRES_PORT}/{POSTGRES_DB}
#
# Пример: postgresql+psycopg://bot_user:bot_password_123@localhost:5432/calendar_bot
#
# Задайте отдельные параметры или DATABASE_URL напрямую (переопределит сборку)
POSTGRES_DB=calendar_bot
POSTGRES_USER=bot_user
DB_PASSWORD=bot_password_123
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
# DATABASE_URL=

# Encryption
ENCRYPTION_KEY=
